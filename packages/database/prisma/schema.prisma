datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// =======================================================
// === 1. CORE & USER MANAGEMENT                       ===
// =======================================================

model Role {
  id    Int    @id @default(autoincrement())
  name  String @db.VarChar(255) // Super Admin, IT Governance, Staff
  users User[]

  @@map("roles")
}

model Department {
  id    Int    @id @default(autoincrement())
  name  String @db.VarChar(255) // SDM & TI, Keuangan, dll
  users User[]

  @@map("departments")
}

model User {
  id                  Int                  @id @default(autoincrement())
  name                String               @db.VarChar(255)
  email               String               @unique @db.VarChar(255)
  password            String               @db.VarChar(255)
  isActive            Boolean              @default(true) @map("is_active")
  roleId              Int                  @map("role_id")
  role                Role                 @relation(fields: [roleId], references: [id])
  departmentId        Int                  @map("department_id")
  department          Department           @relation(fields: [departmentId], references: [id])

  // Relasi Balik
  auditActionPlans    AuditActionPlan[]
  documents           Document[]
  documentHistories   DocumentHistory[]
  maturityAssessments MaturityAssessment[]
  itAssets            ItAsset[]
  assetHandovers      AssetHandover[]      @relation("HandoverUser")
  createdHandovers    AssetHandover[]      @relation("HandoverCreator")
  itRisks             ItRisk[]
  reportedTickets     HelpdeskTicket[]     @relation("ReportedTickets")
  assignedTickets     HelpdeskTicket[]     @relation("AssignedTickets")
  rkapRealizations    RkapRealization[]
  
  // Modul 8: IT Project
  managedProjects     ItProject[]

  @@map("users")
}

model AuditFinding {
  id              Int               @id @default(autoincrement())
  findingCode     String            @unique @map("finding_code") @db.VarChar(255)
  title           String            @db.VarChar(255)
  description     String            @db.Text
  auditorName     String            @map("auditor_name") @db.VarChar(255)
  riskLevel       String            @map("risk_level") @db.VarChar(50) // HIGH, MEDIUM, LOW
  status          String            @db.VarChar(50) // OPEN, IN_PROGRESS, CLOSED
  issueDate       DateTime          @default(now()) @map("issue_date") @db.Timestamp(0)
  actionPlans     AuditActionPlan[]

  @@map("audit_findings")
}

model AuditActionPlan {
  id                Int          @id @default(autoincrement())
  findingId         Int          @map("finding_id")
  finding           AuditFinding @relation(fields: [findingId], references: [id])
  actionDescription String       @map("action_description") @db.Text
  picId             Int          @map("pic_id")
  pic               User         @relation(fields: [picId], references: [id])
  targetDate        DateTime     @map("target_date") @db.Date
  status            String       @default("PENDING") @db.VarChar(50) // PENDING, COMPLETED
  evidenceFile      String?      @map("evidence_file") @db.VarChar(255)
  completedAt       DateTime?    @map("completed_at") @db.Date

  @@map("audit_action_plans")
}

// =======================================================
// === 2. MODUL 1: DOCUMENT TRACKER (SIGAP IT / MANTAP) ===
// =======================================================

model Document {
  id                Int                @id @default(autoincrement())
  docNumber         String             @unique @map("doc_number") @db.VarChar(255)
  title             String             @db.VarChar(255)
  level             String?            @db.VarChar(255) // Level 1: Policy, Level 2: Standard, Level 3: SOP...
  currentVersion    String             @default("v1.0") @map("current_version") @db.VarChar(255)
  status            String?            @db.VarChar(255) // Draft, Active, Need_Review, Archived
  filePath          String?            @map("file_path") @db.VarChar(255)
  publishDate       DateTime?          @map("publish_date") @db.Date
  expiryDate        DateTime?          @map("expiry_date") @db.Date
  createdBy         Int                @map("created_by")
  creator           User               @relation(fields: [createdBy], references: [id])
  histories         DocumentHistory[]
  maturityEvidences MaturityEvidence[]

  @@map("documents")
}

model DocumentHistory {
  id                Int       @id @default(autoincrement())
  documentId        Int       @map("document_id")
  document          Document  @relation(fields: [documentId], references: [id])
  version           String    @db.VarChar(255)
  changeDescription String?   @map("change_description") @db.Text
  filePath          String?   @map("file_path") @db.VarChar(255)
  updatedBy         Int       @map("updated_by")
  updater           User      @relation(fields: [updatedBy], references: [id])
  createdAt         DateTime? @default(now()) @map("created_at") @db.Timestamp(0)

  @@map("document_histories")
}

// =======================================================
// === 3. MODUL 2: IT MATURITY & ASSESSMENT (COBIT/ITMA)===
// =======================================================

model MaturityAssessment {
  id            Int                @id @default(autoincrement())
  year          Int
  frameworkName String             @map("framework_name") @db.VarChar(255) // COBIT 2019, ITMA, dll
  domainCode    String?            @map("domain_code") @db.VarChar(255) // Misal: EDM01, APO12, BAI03
  processName   String             @map("process_name") @db.VarChar(255)
  currentLevel  Decimal            @map("current_level") @db.Decimal(3, 2)
  targetLevel   Decimal            @map("target_level") @db.Decimal(3, 2)
  gapScore      Decimal            @map("gap_score") @db.Decimal(3, 2)
  notes         String?            @db.Text
  updatedBy     Int                @map("updated_by")
  updater       User               @relation(fields: [updatedBy], references: [id])
  updatedAt     DateTime?          @updatedAt @map("updated_at") @db.Timestamp(0)
  evidences     MaturityEvidence[]

  @@map("maturity_assessments")
}

model MaturityEvidence {
  id           Int                @id @default(autoincrement())
  assessmentId Int                @map("assessment_id")
  assessment   MaturityAssessment @relation(fields: [assessmentId], references: [id])
  documentId   Int?               @map("document_id")
  document     Document?          @relation(fields: [documentId], references: [id])
  description  String             @db.Text
  filePath     String?            @map("file_path") @db.VarChar(255)

  @@map("maturity_evidences")
}

// =======================================================
// === 4. MODUL 3: IT ASSET MANAGEMENT (E-BAST)        ===
// =======================================================

model ItAsset {
  id             Int             @id @default(autoincrement())
  assetTag       String          @unique @map("asset_tag") @db.VarChar(255)
  serialNumber   String          @unique @map("serial_number") @db.VarChar(255)
  brand          String          @db.VarChar(255) // Lenovo, Apple, dll
  model          String          @db.VarChar(255) // ThinkPad X1, MacBook Air, dll
  type           String?         @db.VarChar(255) // Laptop, PC, Tablet, Smartphone
  hardwareTier   String?         @map("hardware_tier") @db.VarChar(255) // Tier Developer, Tier Executive, Tier Admin
  purchaseDate   DateTime?       @map("purchase_date") @db.Date
  status         String?         @db.VarChar(255) // Active, In_Stock, Maintenance...
  currentUserId  Int?            @map("current_user_id")
  currentUser    User?           @relation(fields: [currentUserId], references: [id])
  assetHandovers AssetHandover[]

  @@map("it_assets")
}

model AssetHandover {
  id             Int       @id @default(autoincrement())
  handoverNumber String    @unique @map("handover_number") @db.VarChar(255) // Nomor Berita Acara (E-BAST)
  assetId        Int       @map("asset_id")
  asset          ItAsset   @relation(fields: [assetId], references: [id])
  userId         Int       @map("user_id") // Penerima perangkat
  user           User      @relation("HandoverUser", fields: [userId], references: [id])
  handoverDate   DateTime  @map("handover_date") @db.Date
  returnDate     DateTime? @map("return_date") @db.Date
  status         String?   @db.VarChar(255) // Active, Returned
  notes          String?   @db.Text
  evidenceFile   String?   @map("evidence_file") @db.VarChar(255)
  createdBy      Int       @map("created_by") // Petugas IT Gov/Asset
  creator        User      @relation("HandoverCreator", fields: [createdBy], references: [id])

  @@map("asset_handovers")
}

// =======================================================
// === 5. MODUL 4: IT RISK & INCIDENT LOG              ===
// =======================================================

model ItRisk {
  id             Int       @id @default(autoincrement())
  riskCode       String    @unique @map("risk_code") @db.VarChar(255) // R-001, R-002
  title          String    @db.VarChar(255)
  description    String?   @db.Text
  likelihood     Int?
  impact         Int?
  riskScore      Int?      @map("risk_score")
  riskStatus     String?   @map("risk_status") @db.VarChar(255)
  mitigationPlan String?   @map("mitigation_plan") @db.Text
  dueDate        DateTime? @map("due_date") @db.Date
  picId          Int       @map("pic_id")
  pic            User      @relation(fields: [picId], references: [id])
  status         String?   @db.VarChar(255) // Open, In_Progress, Closed

  @@map("it_risks")
}

model HelpdeskTicket {
  id              Int       @id @default(autoincrement())
  ticketNumber    String    @unique @map("ticket_number") @db.VarChar(255) // TICK-2026-001
  title           String    @db.VarChar(255)
  description     String    @db.Text
  ticketType      String    @map("ticket_type") @db.VarChar(50) // INCIDENT, SERVICE_REQUEST
  priority        String    @db.VarChar(50) // HIGH, MEDIUM, LOW
  status          String    @db.VarChar(50) // OPEN, IN_PROGRESS, RESOLVED, CLOSED
  
  reportedBy      Int       @map("reported_by")
  reporter        User      @relation("ReportedTickets", fields: [reportedBy], references: [id])
  
  assignedTo      Int?      @map("assigned_to")
  assignee        User?     @relation("AssignedTickets", fields: [assignedTo], references: [id])

  downtimeMinutes Int?      @map("downtime_minutes") // Opsional, hanya untuk INCIDENT
  rootCause       String?   @map("root_cause") @db.Text // Opsional, hanya untuk INCIDENT
  resolutionNotes String?   @map("resolution_notes") @db.Text // Penjelasan perbaikan

  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt       DateTime  @updatedAt @map("updated_at") @db.Timestamp(0)
  resolvedAt      DateTime? @map("resolved_at") @db.Timestamp(0)

  @@map("helpdesk_tickets")
}

// =======================================================
// === 6. MODUL 5: IT INVESTMENT & RKAP MONITORING     ===
// =======================================================

model RkapBudget {
  id              Int               @id @default(autoincrement())
  year            Int
  code            String            @unique @db.VarChar(255) // Kode COA/Akun Anggaran
  name            String            @db.VarChar(255)
  type            String?           @db.VarChar(255) // CAPEX, OPEX
  allocatedAmount Decimal           @map("allocated_amount") @db.Decimal(15, 2)
  remainingAmount Decimal           @map("remaining_amount") @db.Decimal(15, 2)
  realizations    RkapRealization[]

  @@map("rkap_budgets")
}

model RkapRealization {
  id              Int           @id @default(autoincrement())
  rkapBudgetId    Int           @map("rkap_budget_id")
  rkapBudget      RkapBudget    @relation(fields: [rkapBudgetId], references: [id])
  description     String        @db.Text
  amount          Decimal       @db.Decimal(15, 2)
  transactionDate DateTime      @map("transaction_date") @db.Date
  evidenceFile    String?       @map("evidence_file") @db.VarChar(255)
  inputBy         Int           @map("input_by")
  inputter        User          @relation(fields: [inputBy], references: [id])

  @@map("rkap_realizations")
}

// =======================================================
// === MODUL 7: IT VENDOR & CONTRACT MANAGEMENT        ===
// =======================================================
model ItVendor {
  id              Int       @id @default(autoincrement())
  name            String    @db.VarChar(255)
  serviceType     String    @map("service_type") @db.VarChar(255) // ISP, Software House, Cloud Provider
  contactPerson   String?   @map("contact_person") @db.VarChar(255)
  phoneNumber     String?   @map("phone_number") @db.VarChar(50)
  contractNumber  String    @unique @map("contract_number") @db.VarChar(255)
  contractStart   DateTime  @map("contract_start") @db.Date
  contractEnd     DateTime  @map("contract_end") @db.Date
  slaPercentage   Decimal?  @map("sla_percentage") @db.Decimal(5, 2) // 99.99
  status          String    @db.VarChar(50) // ACTIVE, EXPIRED, RENEWING

  @@map("it_vendors")
}

// =======================================================
// === MODUL 8: IT PROJECT PORTFOLIO (PPM)             ===
// =======================================================
model ItProject {
  id              Int       @id @default(autoincrement())
  projectName     String    @map("project_name") @db.VarChar(255)
  description     String    @db.Text
  managerId       Int       @map("manager_id") // Project Manager (IT)
  manager         User      @relation(fields: [managerId], references: [id])
  startDate       DateTime  @map("start_date") @db.Date
  endDate         DateTime  @map("end_date") @db.Date
  progress        Int       @default(0) // 0 - 100%
  status          String    @db.VarChar(50) // PLANNING, IN_PROGRESS, COMPLETED, ON_HOLD
  
  @@map("it_projects")
}

// =======================================================
// === MODUL 9: IT BROADCAST & ANNOUNCEMENTS           ===
// =======================================================
model Announcement {
  id        Int      @id @default(autoincrement())
  title     String   @db.VarChar(255)
  message   String   @db.Text
  isActive  Boolean  @default(true) @map("is_active")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("announcements")
}